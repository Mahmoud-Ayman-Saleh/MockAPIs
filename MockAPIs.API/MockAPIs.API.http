@host = http://localhost:5167
# Paste the accessToken from a Login/Register response
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..3FoeciWmQZodcjJuZx8jsWHOwhh9uwknYJJTT88HL6k
# Paste a valid project GUID after creating one
@projectId = 32f00875-54bf-41e5-9ea0-4edcd6e114fa
# Paste a valid refresh token from a Login/Register response
@refreshToken = p415Fy/8UAUmYZOCgZ+FKE5WUfMjTtWUqqUrpMKcgjZug16HCjNVwT2Bx06zD4c6dCFRw5WPKCSKbwOa20spbw==

### ══════════════════════════════════════════════════════
###   AUTH ENDPOINTS
### ══════════════════════════════════════════════════════

### ─── Register ────────────────────────────────────────
POST {{host}}/api/auth/Register
Content-Type: application/json

{
  "userName": "testuser",
  "email": "testuser@example.com",
  "password": "Test@1234"
}

### ─── Login ───────────────────────────────────────────
POST {{host}}/api/auth/Login
Content-Type: application/json

{
  "userName": "testuser",
  "password": "Test@1234"
}

### ─── Refresh Token ───────────────────────────────────
POST {{host}}/api/auth/RefreshToken
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

### ─── Login with wrong password (expect 401) ─────────
POST {{host}}/api/auth/Login
Content-Type: application/json

{
  "userName": "testuser",
  "password": "WrongPassword1!"
}

### ─── Register duplicate email (expect 400) ──────────
POST {{host}}/api/auth/Register
Content-Type: application/json

{
  "userName": "testuser2",
  "email": "testuser@example.com",
  "password": "Test@1234"
}



### ══════════════════════════════════════════════════════
###   PROJECT ENDPOINTS
### ══════════════════════════════════════════════════════

### ─── Get All Projects (no token, expect 401) ───────────
GET {{host}}/api/project

### ─── Create Project (expect 201) ──────────────────────
POST {{host}}/api/project
Content-Type: application/json
Authorization: Bearer {{token}}

"My Second Project"

### ─── Get All Projects (expect 200) ────────────────────
GET {{host}}/api/project
Authorization: Bearer {{token}}

### ─── Get Project By ID (expect 200) ───────────────────
# Replace @projectId at the top with a real GUID from Create / Get All
GET {{host}}/api/project/{{projectId}}
Authorization: Bearer {{token}}

### ─── Rename Project (expect 200) ──────────────────────
PUT {{host}}/api/project/{{projectId}}/rename
Content-Type: application/json
Authorization: Bearer {{token}}

"Renamed Project"

### ─── Get Project by non-existent ID (expect 404) ───────
GET {{host}}/api/project/00000000-0000-0000-0000-000000000000
Authorization: Bearer {{token}}

### ─── Delete non-existent Project (expect 404) ──────────
DELETE {{host}}/api/project/00000000-0000-0000-0000-000000000000
Authorization: Bearer {{token}}

### ─── Delete Project (expect 200) ──────────────────────
DELETE {{host}}/api/project/{{projectId}}
Authorization: Bearer {{token}}



### ══════════════════════════════════════════════════════
###   RESOURCE ENDPOINTS
### ══════════════════════════════════════════════════════

### ─── Create Resource (expect 201) ─────────────────────
POST {{host}}/api/resource/1
Content-Type: application/json
Authorization: Bearer {{token}}

"New Resource"
